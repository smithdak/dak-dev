{
  "name": "dak-dev",
  "version": "1.0.0",
  "description": "Personal website for blogging, showcasing work, and promoting skills.",
  "main": "index.js",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,css,md}\"",
    "analyze": "ANALYZE=true next build --webpack",
    "validate:content": "tsx scripts/validate-posts.ts",
    "validate:content:all": "tsx scripts/validate-posts.ts --all",
    "images:process": "tsx scripts/process-images.ts",
    "images:validate": "tsx scripts/process-images.ts --validate",
    "images:check": "tsx scripts/process-images.ts --check",
    "images:placeholder": "tsx scripts/generate-placeholder-images.ts",
    "thumbnail:create": "tsx scripts/generate-thumbnail.ts",
    "resume:generate": "tsx scripts/generate-resume-pdf.ts",
    "rss:test": "tsx scripts/test-rss-feed.ts",
    "publish:prepare": "tsx scripts/publish-prepare.ts",
    "publish:prepare:fix": "tsx scripts/publish-prepare.ts --fix",
    "publish:prepare:all": "tsx scripts/publish-prepare.ts --all",
    "generate:og": "tsx scripts/generate-default-og.ts"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/smithdak/dak-dev.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.33.4",
  "engines": {
    "node": ">=22.22.2"
  },
  "bugs": {
    "url": "https://github.com/smithdak/dak-dev/issues"
  },
  "homepage": "https://github.com/smithdak/dak-dev#readme",
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^12.42.2",
    "gray-matter": "^4.0.3",
    "hast-util-to-html": "^9.0.5",
    "next": "^16.2.10",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "reading-time": "^1.5.0",
    "rehype-pretty-code": "^0.14.4",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "sharp": "^0.35.3",
    "shiki": "^4.3.1",
    "unified": "^11.0.5"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^16.2.10",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/hast": "^3.0.4",
    "@types/mdx": "^2.0.14",
    "@types/node": "^26.1.0",
    "@types/pdfkit": "^0.17.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/sharp": "^0.32.0",
    "autoprefixer": "^10.5.2",
    "eslint": "^9.39.2",
    "eslint-config-next": "^16.2.10",
    "pdfkit": "^0.19.1",
    "postcss": "^8.5.16",
    "prettier": "^3.9.4",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.23.0",
    "typescript": "6.0.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "unrs-resolver"
    ],
    "overrides": {
      "postcss@<8.5.10": ">=8.5.10"
    }
  }
}
